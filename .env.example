# ============================================================
#  경매·공매 AI 에이전트 환경변수 (.env 로 복사 후 사용)
#  실제 키는 절대 GitHub에 올리지 마세요.
# ============================================================

# ── Mock 모드 (true: 실제 API 키 없이 동작) ─────────────────
USE_MOCK_APIS=true

# ── Claude API ──────────────────────────────────────────────
USE_AI=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 공공데이터포털 (국토부 실거래가 + 온비드) ───────────────
PUBLIC_DATA_SERVICE_KEY=
ONBID_API_KEY=

# ── 텔레그램 봇 ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Slack Incoming Webhook ─────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Discord Webhook ────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── 이메일(SMTP) ───────────────────────────────────────────
# Gmail 사용 시: 2단계 인증 + 앱 비밀번호 발급해서 SMTP_PASSWORD 에 입력
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# ── 경로 ───────────────────────────────────────────────────
DB_PATH=data/auction_agent.db
EXPORT_DIR=data/exports
FIXTURE_DIR=data/fixtures

# ── 관심 대상 ─────────────────────────────────────────────
TARGET_REGIONS=서울특별시,경기도,인천광역시
TARGET_TYPES=아파트,오피스텔,빌라

# ── 수익 계산 기본값 ────────────────────────────────────────
ACQUISITION_TAX_RATE=0.035
DEFAULT_REPAIR_COST=500
DEFAULT_EVICTION_COST=300
FINANCE_RATE=0.04

# ── 사용자 선호 기본값 ──────────────────────────────────────
DEFAULT_MIN_PROFIT_MAN=3000
DEFAULT_MIN_ROI=0.05
