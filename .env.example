# ============================================================
#  경매·공매 AI 에이전트 환경변수 (.env 로 복사 후 사용)
#  실제 키는 절대 GitHub에 올리지 마세요.
#  값에 따옴표/공백 넣지 마세요. 한 줄에 KEY=VALUE 형식.
# ============================================================

# ── Mock 모드 (true: 실제 API 키 없이 동작) ─────────────────
# 기본값 true 로 두면 실제 외부 API 호출 없이 mock 으로 끝까지 실행됩니다.
USE_MOCK_APIS=true

# ── Claude API ──────────────────────────────────────────────
USE_AI=false
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 공공데이터포털 (국토부 실거래가 + 온비드) ───────────────
PUBLIC_DATA_SERVICE_KEY=your_public_data_key_here
ONBID_API_KEY=your_onbid_api_key_here

# ── 입지 분석 API (v2.0) ───────────────────────────────────
# 카카오: 주소→좌표, 주변 시설 검색  (https://developers.kakao.com)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
# 네이버 검색(개발 호재 뉴스)  (https://developers.naver.com)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ── 텔레그램 봇 ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Slack Incoming Webhook ─────────────────────────────────
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ── Discord Webhook ────────────────────────────────────────
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ── 이메일(SMTP) ───────────────────────────────────────────
# Gmail 사용 시: 2단계 인증 + 앱 비밀번호 발급해서 SMTP_PASSWORD 에 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@example.com
SMTP_TO=your_email@example.com
SMTP_USE_TLS=true

# ── 경로 ───────────────────────────────────────────────────
DB_PATH=data/auction_agent.db
DATABASE_URL=sqlite:///data/auction_agent.db
EXPORT_DIR=data/exports
FIXTURE_DIR=data/fixtures

# ── 외부 영구 DB (Turso/libSQL) - 선택 ─────────────────────
# 설정 안 하면 로컬 SQLite 사용. Streamlit Cloud 의 ephemeral fs 한계
# 해결을 원하면 Turso 가입 후 무료 DB 생성 + 토큰 발급.
# https://turso.tech (500GB 읽기/월 무료)
# pip install libsql-experimental 필요.
TURSO_DATABASE_URL=your_turso_database_url_here
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ── 관심 대상 ─────────────────────────────────────────────
TARGET_REGIONS=서울특별시,경기도,인천광역시
TARGET_TYPES=아파트,오피스텔,빌라

# ── 수익 계산 기본값 ────────────────────────────────────────
ACQUISITION_TAX_RATE=0.035
DEFAULT_REPAIR_COST=500
DEFAULT_EVICTION_COST=300
FINANCE_RATE=0.04

# ── 사용자 선호 기본값 ──────────────────────────────────────
DEFAULT_MIN_PROFIT_MAN=3000
DEFAULT_MIN_ROI=0.05

# ── 사용자 프로필 (v2.0 시나리오 의사결정 / 자기자본 5천~2억) ──
USER_CAPITAL_MAX=200000000          # 자기자본 상한 (2억)
USER_CAPITAL_MIN=50000000           # 자기자본 하한 (5천만)
USER_ANNUAL_INCOME=60000000         # 연소득 (6천만)
USER_OTHER_DEBT_MONTHLY=300000      # 월 기타 부채 상환액
USER_LOAN_AVAILABLE=500000000       # 대출 가능액
USER_SCENARIO_WEIGHTS=0.3,0.4,0.3   # 단타/임대/실거주 가중치
USER_RISK_APPETITE=medium           # low/medium/high
USER_MIN_ROI=0.08                   # 최소 기대 ROI
USER_MAX_RISK_SCORE=6               # 허용 최대 위험 점수
USER_MAX_INHERIT_COST=10000000      # 인수금액 한도 (1천만)
USER_INTEREST_REGIONS=서울 마포구,서울 성동구,경기 성남시
USER_ANNUAL_APPRECIATION=0.03       # 연 시세상승률 가정

# ── Mock / Stress / 기본 설정 ───────────────────────────────
MOCK_DEFAULT_COUNT=100
MOCK_DEFAULT_SEED=42
STRESS_DEFAULT_COUNT=500
STRESS_DEFAULT_QUERIES=5
DEFAULT_TOP_N=5
