# ============================================================
#  Streamlit Cloud secrets 예시
#  - 이 파일을 secrets.toml 로 복사한 뒤 값 채우기
#  - secrets.toml 은 .gitignore 에 의해 git 에 올라가지 않음
#  - Streamlit Cloud 에서는 Settings -> Secrets 메뉴에 동일 내용을
#    붙여넣으면 됨
# ============================================================

# Mock-first 모드. 키 없으면 그대로 두면 모든 데모 동작이 mock으로 처리됨.
USE_MOCK_APIS = "true"

# Claude API (USE_AI=true 일 때만 호출)
USE_AI = "false"
ANTHROPIC_API_KEY = ""
ANTHROPIC_MODEL = "claude-sonnet-4-6"

# 공공데이터포털 (국토부 실거래가 + 온비드 공매)
PUBLIC_DATA_SERVICE_KEY = ""
ONBID_API_KEY = ""

# 텔레그램 봇 (USE_MOCK_APIS=false 일 때만 실제 발송)
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""

# Slack Incoming Webhook (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL = ""

# Discord Webhook (서버 설정 -> 연동 -> 웹후크)
DISCORD_WEBHOOK_URL = ""

# 이메일 (SMTP). Gmail 은 앱 비밀번호 사용
SMTP_HOST = ""
SMTP_PORT = "587"
SMTP_USER = ""
SMTP_PASSWORD = ""
SMTP_FROM = ""
SMTP_TO = ""
SMTP_USE_TLS = "true"

# DB / 경로 — Streamlit Cloud 의 ephemeral filesystem 사용 가능
DB_PATH = "data/auction_agent.db"
EXPORT_DIR = "data/exports"
FIXTURE_DIR = "data/fixtures"

# Turso (외부 영구 DB) - 선택
# Streamlit Cloud 재시작에도 데이터 유지하려면 turso.tech 가입 후 입력
TURSO_DATABASE_URL = ""
TURSO_AUTH_TOKEN = ""

# 관심 대상 기본값
TARGET_REGIONS = "서울특별시,경기도,인천광역시"
TARGET_TYPES = "아파트,오피스텔,빌라"

# 수익 계산 기본값
ACQUISITION_TAX_RATE = "0.035"
DEFAULT_REPAIR_COST = "500"
DEFAULT_EVICTION_COST = "300"
FINANCE_RATE = "0.04"

# 사용자 선호 기본값
DEFAULT_MIN_PROFIT_MAN = "3000"
DEFAULT_MIN_ROI = "0.05"
